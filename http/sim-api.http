@baseUrl = http://localhost:3000
@adminApiKey = REEMPLAZA_CON_TU_ADMIN_API_KEY
@appApiKey = REEMPLAZA_CON_TU_APP_API_KEY
@applicationId = 11111111-1111-4111-8111-111111111111
@customerId = PEGA_AQUI_EL_CUSTOMER_ID_CREADO
@licenseId = 33333333-3333-4333-8333-333333333333
@serialNumber = ABCDE-23456-FGHJK-789KL-MNPQR

# Antes de probar, ejecuta docs/database-schema.sql.
# Copia los ids devueltos por las requests create en applicationId, customerId y licenseId.
# Despues de crear una licencia, copia data.serialNumber en serialNumber.
# Las requests administrativas requieren ADMIN_API_KEY y una IP permitida en ADMIN_ALLOWED_IPS.
# La validacion con APP_API_KEY esta pensada para exponerse a internet.

### Health
GET {{baseUrl}}/health

### Create application
POST {{baseUrl}}/api/v1/applications
Content-Type: application/json
x-api-key: {{adminApiKey}}

{
  "name": "SIM Desktop",
  "code": "SIM-DESKTOP"
}

### List applications
GET {{baseUrl}}/api/v1/applications?q=sim&isActive=true&limit=25&offset=0
x-api-key: {{adminApiKey}}

### Get application by id
GET {{baseUrl}}/api/v1/applications/{{applicationId}}
x-api-key: {{adminApiKey}}

### Update application
PATCH {{baseUrl}}/api/v1/applications/{{applicationId}}
Content-Type: application/json
x-api-key: {{adminApiKey}}

{
  "name": "SIM Desktop",
  "isActive": true
}

### Create customer
POST {{baseUrl}}/api/v1/customers
Content-Type: application/json
x-api-key: {{adminApiKey}}

{
  "externalRef": "demo-customer",
  "name": "Cliente Demo",
  "email": "cliente@example.com",
  "rfc": "XAXX010101000",
  "fiscalRegime": "General de Ley Personas Morales",
  "postalCode": "64000"
}

### List customers
GET {{baseUrl}}/api/v1/customers?q=cliente&isActive=true&limit=25&offset=0
x-api-key: {{adminApiKey}}

### Get customer by id
GET {{baseUrl}}/api/v1/customers/{{customerId}}
x-api-key: {{adminApiKey}}

### Update customer
PATCH {{baseUrl}}/api/v1/customers/{{customerId}}
Content-Type: application/json
x-api-key: {{adminApiKey}}

{
  "email": "cliente.admin@example.com",
  "postalCode": "64000",
  "isActive": true
}

### Create license with customer
POST {{baseUrl}}/api/v1/licenses
Content-Type: application/json
x-api-key: {{adminApiKey}}

{
  "applicationId": "{{applicationId}}",
  "customer": {
    "externalRef": "demo-customer",
    "name": "Cliente Demo",
    "email": "cliente@example.com",
    "rfc": "XAXX010101000",
    "fiscalRegime": "General de Ley Personas Morales",
    "postalCode": "64000"
  },
  "validFrom": "2026-06-26T00:00:00.000Z",
  "validUntil": "2027-06-26T00:00:00.000Z",
  "maxActivations": 1,
  "metadata": {
    "plan": "pro",
    "ownerName": "Cliente Demo"
  }
}

### Create license with existing customer
POST {{baseUrl}}/api/v1/licenses
Content-Type: application/json
x-api-key: {{adminApiKey}}

{
  "applicationId": "{{applicationId}}",
  "customerId": "{{customerId}}",
  "validFrom": "2026-06-26T00:00:00.000Z",
  "validUntil": "2027-06-26T00:00:00.000Z",
  "maxActivations": 1,
  "metadata": {
    "plan": "pro"
  }
}

### List licenses
GET {{baseUrl}}/api/v1/licenses?applicationId={{applicationId}}&customerId={{customerId}}&status=active&limit=25&offset=0
x-api-key: {{adminApiKey}}

### Get license by id
GET {{baseUrl}}/api/v1/licenses/{{licenseId}}
x-api-key: {{adminApiKey}}

### Validate license with app key
POST {{baseUrl}}/api/v1/licenses/validate
Content-Type: application/json
x-api-key: {{appApiKey}}

{
  "serialNumber": "{{serialNumber}}",
  "applicationId": "{{applicationId}}"
}

### Validate license with admin key
POST {{baseUrl}}/api/v1/licenses/validate
Content-Type: application/json
x-api-key: {{adminApiKey}}

{
  "serialNumber": "{{serialNumber}}",
  "applicationId": "{{applicationId}}",
  "customerId": "{{customerId}}"
}

### Revoke license
POST {{baseUrl}}/api/v1/licenses/{{licenseId}}/revoke
Content-Type: application/json
x-api-key: {{adminApiKey}}

{
  "reason": "Prueba manual desde IDE"
}

### Renew license
POST {{baseUrl}}/api/v1/licenses/{{licenseId}}/renew
Content-Type: application/json
x-api-key: {{adminApiKey}}

{
  "validUntil": "2028-06-26T00:00:00.000Z"
}
